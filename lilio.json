{
  "lilio": {
    "chunk_size": "1MB",
    "replication_factor": 2,
    "metadata_path": "./lilio_data/metadata",
    "api_port": 8080
  },
    "metrics": {
      "enabled": true,
      "type": "prometheus"
    },
  "storages": [
    {
      "name": "local-1",
      "type": "local",
      "priority": 1,
      "options": {
        "path": "./lilio_data/storage/local-1"
      }
    },
    {
      "name": "local-3",
      "type": "local",
      "priority": 3,
      "options": {
        "path": "./lilio_data/storage/local-3"
      }
    },
    {
      "name": "gdrive-1",
      "type": "gdrive",
      "priority": 10,
      "options": {
        "credentials": "./lilio-drive-1-primarykey.json"
      }
    }
  ]
}